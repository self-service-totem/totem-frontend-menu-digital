// Security Rules de Firestore — DEMO del totem (sin Auth).
//
// Acceso abierto con FECHA DE EXPIRACIÓN: cualquiera con la config puede leer/escribir
// hasta la fecha límite. Es deliberadamente permisivo para la demo; NO usar en
// producción. Para cerrar: habilitar Auth Anónima y reemplazar la condición por
// `request.auth != null`.
//
// Cómo aplicar: consola Firebase → Firestore Database → pestaña "Rules" → pegar → Publicar.
// Recordá mover la fecha si extendés la demo.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 9, 1);
    }
  }
}
