# Copiar a .env y completar con la config del proyecto Firebase.
# Poner VITE_USE_FIREBASE=false para correr 100% local (solo localStorage, sin sync).
VITE_USE_FIREBASE=true

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3) — anti-abuso para Firestore/Storage.
# Obtener en: Firebase Console → App Check → Apps → reCAPTCHA v3 site key.
# Después de configurar, activar Enforce en: App Check → APIs → Firestore + Storage.
VITE_FIREBASE_APP_CHECK_KEY=
